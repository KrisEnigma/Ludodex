# AdMob (set VITE_ADMOB_USE_TEST_IDS=false to use production IDs)
VITE_ADMOB_USE_TEST_IDS=true
VITE_ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
VITE_ADMOB_INTERSTITIAL_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx

# RevenueCat
VITE_REVENUECAT_API_KEY=your_revenuecat_public_sdk_key

# Sentry (leave blank to disable; in production, set to the DSN from sentry.io)
VITE_SENTRY_DSN=

# PostHog (leave VITE_POSTHOG_KEY blank to disable; set to project API key in production)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
