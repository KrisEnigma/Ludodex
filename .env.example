# AdMob (set VITE_ADMOB_USE_TEST_IDS=false to use production IDs)
VITE_ADMOB_USE_TEST_IDS=true
VITE_ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
VITE_ADMOB_INTERSTITIAL_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx

# RevenueCat
VITE_REVENUECAT_API_KEY=your_revenuecat_public_sdk_key

# Sentry (leave blank to disable; in production, set to the DSN from sentry.io)
VITE_SENTRY_DSN=

# PostHog (leave VITE_POSTHOG_KEY blank to disable; set to project API key in production)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Share footer URL (shown at the bottom of the share string; leave blank to omit)
VITE_SHARE_BASE_URL=https://ludodex.krisenigma.com

# Remote puzzle catalog URL. Leave unset to use ${VITE_SHARE_BASE_URL}/api/puzzles
# (the editor's Worker->R2 store). Set only to point the game at a different
# host, e.g. a CDN.
# VITE_PUZZLES_URL=https://ludodex.krisenigma.com/api/puzzles

# Day-1 anchor for the daily puzzle sequence (YYYY-MM-DD, device-local midnight).
# Set this to (public launch date − 7 days) so launch day = day 8 and there's a
# 7-puzzle starter archive on launch. Falls back to a code default if unset.
VITE_LAUNCH_DATE=2026-06-22
